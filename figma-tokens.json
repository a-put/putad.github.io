{
  "$schema": "https://raw.githubusercontent.com/token-studio/token-studio-schema/main/schema.json",
  "$metadata": {
    "tokenSetOrder": ["global", "typography", "component"]
  },

  "global": {
    "color": {
      "bg": {
        "value": "#f5f5f7",
        "type": "color",
        "description": "Page background"
      },
      "surface": {
        "value": "#ffffff",
        "type": "color",
        "description": "Card and panel background"
      },
      "text": {
        "primary": {
          "value": "#1d1d1f",
          "type": "color",
          "description": "Headings and emphasis"
        },
        "secondary": {
          "value": "#6e6e73",
          "type": "color",
          "description": "Body text"
        },
        "tertiary": {
          "value": "#86868b",
          "type": "color",
          "description": "Captions, metadata, placeholders"
        }
      },
      "accent": {
        "value": "#0071e3",
        "type": "color",
        "description": "Links, active states, explainer card border"
      },
      "border": {
        "value": "rgba(0, 0, 0, 0.08)",
        "type": "color",
        "description": "Dividers and card outlines"
      }
    },

    "borderRadius": {
      "card": {
        "value": "14",
        "type": "borderRadius",
        "description": "Cards, avatar, modal panels"
      },
      "button": {
        "value": "8",
        "type": "borderRadius",
        "description": "Tab buttons, social icon containers"
      },
      "input": {
        "value": "10",
        "type": "borderRadius",
        "description": "Form inputs and textareas"
      },
      "pill": {
        "value": "980",
        "type": "borderRadius",
        "description": "Badges, skill tags, submit button"
      }
    },

    "boxShadow": {
      "sm": {
        "value": [
          {
            "x": "0",
            "y": "1",
            "blur": "4",
            "spread": "0",
            "color": "rgba(0, 0, 0, 0.06)",
            "type": "dropShadow"
          },
          {
            "x": "0",
            "y": "1",
            "blur": "2",
            "spread": "0",
            "color": "rgba(0, 0, 0, 0.04)",
            "type": "dropShadow"
          }
        ],
        "type": "boxShadow",
        "description": "Cards, avatar, social icon buttons"
      },
      "md": {
        "value": [
          {
            "x": "0",
            "y": "6",
            "blur": "24",
            "spread": "0",
            "color": "rgba(0, 0, 0, 0.12)",
            "type": "dropShadow"
          },
          {
            "x": "0",
            "y": "2",
            "blur": "8",
            "spread": "0",
            "color": "rgba(0, 0, 0, 0.08)",
            "type": "dropShadow"
          }
        ],
        "type": "boxShadow",
        "description": "Hover state elevation, modals"
      },
      "modal": {
        "value": [
          {
            "x": "0",
            "y": "24",
            "blur": "80",
            "spread": "0",
            "color": "rgba(0, 0, 0, 0.30)",
            "type": "dropShadow"
          }
        ],
        "type": "boxShadow",
        "description": "Publication explainer modal panels"
      }
    },

    "spacing": {
      "2":  { "value": "2",  "type": "spacing" },
      "4":  { "value": "4",  "type": "spacing" },
      "8":  { "value": "8",  "type": "spacing" },
      "12": { "value": "12", "type": "spacing" },
      "16": { "value": "16", "type": "spacing" },
      "20": { "value": "20", "type": "spacing" },
      "24": { "value": "24", "type": "spacing" },
      "32": { "value": "32", "type": "spacing" },
      "40": { "value": "40", "type": "spacing" },
      "48": { "value": "48", "type": "spacing" },
      "80": { "value": "80", "type": "spacing" }
    }
  },

  "typography": {
    "fontFamily": {
      "base": {
        "value": "Inter",
        "type": "fontFamilies",
        "description": "Figma substitute for SF Pro. Use SF Pro on macOS if available."
      }
    },

    "fontSize": {
      "micro":       { "value": "10", "type": "fontSizes", "description": "0.65 rem — badge text" },
      "label":       { "value": "11", "type": "fontSizes", "description": "0.68 rem — subsection labels, explainer headline" },
      "tinyCaption": { "value": "12", "type": "fontSizes", "description": "0.72 rem — timeline year, period italic" },
      "caption":     { "value": "13", "type": "fontSizes", "description": "0.82 rem — institution, edu-period, exp-meta" },
      "body":        { "value": "14", "type": "fontSizes", "description": "0.875 rem — main body text, tab buttons" },
      "bodyMd":      { "value": "14", "type": "fontSizes", "description": "0.9 rem — explainer body, form inputs" },
      "pub":         { "value": "15", "type": "fontSizes", "description": "0.925 rem — publication title" },
      "base":        { "value": "16", "type": "fontSizes", "description": "1 rem — exp-role, proj-title" },
      "sectionTitle":{ "value": "22", "type": "fontSizes", "description": "1.4 rem — section headings" },
      "headerName":  { "value": "30", "type": "fontSizes", "description": "1.875 rem / Tailwind text-3xl — page name h1" }
    },

    "fontWeight": {
      "regular": { "value": "400", "type": "fontWeights" },
      "medium":  { "value": "500", "type": "fontWeights" },
      "semibold":{ "value": "600", "type": "fontWeights" },
      "bold":    { "value": "700", "type": "fontWeights" }
    },

    "lineHeight": {
      "tight":   { "value": "1.2",   "type": "lineHeights", "description": "Headings" },
      "snug":    { "value": "1.4",   "type": "lineHeights", "description": "Card titles, publication titles" },
      "normal":  { "value": "1.5",   "type": "lineHeights", "description": "General text" },
      "relaxed": { "value": "1.625", "type": "lineHeights", "description": "About paragraph (leading-relaxed)" },
      "loose":   { "value": "1.65",  "type": "lineHeights", "description": "Experience bullet list items" },
      "airy":    { "value": "1.7",   "type": "lineHeights", "description": "Explainer body, publication layman summary" }
    },

    "letterSpacing": {
      "tight":      { "value": "-0.03em", "type": "letterSpacing", "description": "Headings (h1, section titles)" },
      "slightNeg":  { "value": "-0.01em", "type": "letterSpacing", "description": "Tab buttons, form labels" },
      "normal":     { "value": "0",       "type": "letterSpacing" },
      "wide":       { "value": "0.02em",  "type": "letterSpacing", "description": "Badge text" },
      "wider":      { "value": "0.04em",  "type": "letterSpacing", "description": "Project status pill" },
      "widest":     { "value": "0.06em",  "type": "letterSpacing", "description": "Timeline year label" },
      "extraWide":  { "value": "0.08em",  "type": "letterSpacing", "description": "Publication modal journal label" },
      "ultraWide":  { "value": "0.09em",  "type": "letterSpacing", "description": "Subsection labels, explainer headline" }
    }
  },

  "component": {
    "header": {
      "bg":            { "value": "rgba(255, 255, 255, 0.88)", "type": "color" },
      "blurAmount":    { "value": "20px", "type": "other", "description": "backdrop-filter blur" },
      "paddingY":      { "value": "{global.spacing.40}", "type": "spacing" },
      "paddingX":      { "value": "{global.spacing.24}", "type": "spacing" },
      "innerMaxWidth": { "value": "900", "type": "sizing" },
      "gap":           { "value": "{global.spacing.24}", "type": "spacing" }
    },

    "avatar": {
      "width":        { "value": "96",  "type": "sizing" },
      "borderRadius": { "value": "{global.borderRadius.card}", "type": "borderRadius" },
      "shadow":       { "value": "{global.boxShadow.sm}", "type": "boxShadow" }
    },

    "socialIconButton": {
      "size":         { "value": "32",  "type": "sizing" },
      "iconSize":     { "value": "20",  "type": "sizing" },
      "borderRadius": { "value": "{global.borderRadius.button}", "type": "borderRadius" },
      "bg":           { "value": "{global.color.surface}", "type": "color" },
      "shadow":       { "value": "{global.boxShadow.sm}", "type": "boxShadow" },
      "shadowHover":  { "value": "{global.boxShadow.md}", "type": "boxShadow" },
      "scaleHover":   { "value": "1.12", "type": "other" }
    },

    "sidebar": {
      "width":       { "value": "140", "type": "sizing", "description": "clamp(120px, 14vw, 160px)" },
      "gap":         { "value": "2.4", "type": "spacing" },
      "stickyTop":   { "value": "{global.spacing.40}", "type": "spacing" }
    },

    "tabButton": {
      "paddingY":       { "value": "7",  "type": "spacing" },
      "paddingX":       { "value": "12", "type": "spacing" },
      "fontSize":       { "value": "{typography.fontSize.body}", "type": "fontSizes" },
      "borderRadius":   { "value": "{global.borderRadius.button}", "type": "borderRadius" },
      "colorDefault":   { "value": "{global.color.text.secondary}", "type": "color" },
      "colorHover":     { "value": "{global.color.text.primary}", "type": "color" },
      "colorActive":    { "value": "{global.color.text.primary}", "type": "color" },
      "bgDefault":      { "value": "transparent", "type": "color" },
      "bgHover":        { "value": "rgba(0, 0, 0, 0.05)", "type": "color" },
      "bgActive":       { "value": "rgba(0, 0, 0, 0.07)", "type": "color" },
      "weightActive":   { "value": "{typography.fontWeight.semibold}", "type": "fontWeights" }
    },

    "card": {
      "bg":           { "value": "{global.color.surface}", "type": "color" },
      "borderRadius": { "value": "{global.borderRadius.card}", "type": "borderRadius" },
      "shadow":       { "value": "{global.boxShadow.sm}", "type": "boxShadow" },
      "paddingY":     { "value": "{global.spacing.20}", "type": "spacing" },
      "paddingX":     { "value": "{global.spacing.24}", "type": "spacing" }
    },

    "educationCard": {
      "paddingY":          { "value": "17", "type": "spacing" },
      "paddingX":          { "value": "22", "type": "spacing" },
      "gap":               { "value": "{global.spacing.16}", "type": "spacing" },
      "degreeSize":        { "value": "{typography.fontSize.bodyMd}", "type": "fontSizes" },
      "degreeWeight":      { "value": "{typography.fontWeight.semibold}", "type": "fontWeights" },
      "degreeColor":       { "value": "{global.color.text.primary}", "type": "color" },
      "institutionSize":   { "value": "{typography.fontSize.caption}", "type": "fontSizes" },
      "institutionColor":  { "value": "{global.color.text.secondary}", "type": "color" },
      "periodSize":        { "value": "13", "type": "fontSizes" },
      "periodColor":       { "value": "{global.color.text.tertiary}", "type": "color" },
      "locationSize":      { "value": "12", "type": "fontSizes" },
      "locationColor":     { "value": "{global.color.text.tertiary}", "type": "color" }
    },

    "recognitionRow": {
      "paddingY":      { "value": "11", "type": "spacing" },
      "borderColor":   { "value": "{global.color.border}", "type": "color" },
      "titleSize":     { "value": "{typography.fontSize.body}", "type": "fontSizes" },
      "titleColor":    { "value": "{global.color.text.primary}", "type": "color" },
      "yearSize":      { "value": "13", "type": "fontSizes" },
      "yearColor":     { "value": "{global.color.text.tertiary}", "type": "color" }
    },

    "subsectionLabel": {
      "fontSize":      { "value": "{typography.fontSize.label}", "type": "fontSizes" },
      "fontWeight":    { "value": "{typography.fontWeight.semibold}", "type": "fontWeights" },
      "color":         { "value": "{global.color.text.tertiary}", "type": "color" },
      "letterSpacing": { "value": "{typography.letterSpacing.ultraWide}", "type": "letterSpacing" },
      "marginTop":     { "value": "{global.spacing.32}", "type": "spacing" },
      "marginBottom":  { "value": "12", "type": "spacing" }
    },

    "explainerCard": {
      "bgGradientFrom": { "value": "rgba(0, 113, 227, 0.06)", "type": "color" },
      "bgGradientTo":   { "value": "rgba(0, 113, 227, 0.02)", "type": "color" },
      "borderLeft":     { "value": "4px solid #0071e3", "type": "other" },
      "borderRadius":   { "value": "{global.borderRadius.card}", "type": "borderRadius" },
      "paddingY":       { "value": "{global.spacing.20}", "type": "spacing" },
      "paddingX":       { "value": "22", "type": "spacing" },
      "marginBottom":   { "value": "28", "type": "spacing" },
      "headlineSize":   { "value": "{typography.fontSize.label}", "type": "fontSizes" },
      "headlineColor":  { "value": "{global.color.accent}", "type": "color" },
      "bodySize":       { "value": "{typography.fontSize.bodyMd}", "type": "fontSizes" },
      "bodyColor":      { "value": "{global.color.text.secondary}", "type": "color" },
      "bodyLineHeight": { "value": "{typography.lineHeight.airy}", "type": "lineHeights" }
    }
  }
}
